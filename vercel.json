{
  "version": 2,
  "installCommand": "pnpm install",
  "buildCommand": "pnpm run build:vercel",
  "functions": {
    "artifacts/api-server/api/index.ts": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/artifacts/api-server/api/index" }
  ]
}
